{
  "version": 2,
  "builds": [
    { "src": "dist/server/server.js", "use": "@vercel/node" },
    { "src": "dist/client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/_next/static/(.*)", "dest": "/dist/client/_next/static/$1" },
    { "src": "/assets/(.*)", "dest": "/dist/client/assets/$1" },
    { "src": "/(.*)", "dest": "dist/server/server.js" }
  ]
}
